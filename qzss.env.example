# qzss-decoder.service が読み込む環境変数ファイル。
# このファイルをコピーして qzss.env という名前で保存し、内容を書き換える。
# qzss.env 自体はgit管理しない(環境ごとに値が違うため .gitignore 済み)。
#
#   cp qzss.env.example qzss.env
#   nano qzss.env

# 受信機のシリアルポート(接続後に `ls /dev/ttyUSB* /dev/ttyACM*` で確認)
QZSS_SERIAL_PORT=/dev/ttyUSB0
QZSS_BAUDRATE=115200

# 送信先。Web配信(Cloud Run)を使う場合はそのURL、
# ローカルkiosk表示だけの場合は http://localhost:8080/ingest
QZSS_CLOUD_URL=http://localhost:8080/ingest
QZSS_INGEST_TOKEN=

# OTA更新失敗・本体温度異常・サービス自動再起動時にDiscordへ通知する。
# Discordサーバーの チャンネル設定 → 連携サービス → ウェブフックを作成 →
# 「ウェブフックURLをコピー」で取得したURLをそのまま貼り付ける。
# 空欄のままなら通知は送られない(通常のログ出力のみ)。詳細はDISCORD_SETUP.md参照
DISCORD_WEBHOOK_URL=

# 本体温度の閾値(℃)。TEMP_WARN以上でログに記録、TEMP_CRITICAL以上でDiscord通知
TEMP_WARN=70
TEMP_CRITICAL=80

# デバイス管理ダッシュボードに表示される端末名(空欄ならhostnameを使う)。
# 管理サイトでこの拠点に「対象地域」を割り当てた場合、地図側で
# ?device=<この値> を付けて開いた画面がその地域に固定される
QZSS_DEVICE_ID=
